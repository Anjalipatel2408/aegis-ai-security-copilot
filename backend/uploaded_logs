from fastapi import FastAPI, UploadFile, File
import os

app = FastAPI()

UPLOAD_DIR = "uploads"
os.makedirs(UPLOAD_DIR, exist_ok=True)  # folder ના હોય તો બનાવે

@app.post("/upload-log")
async def upload_log(file: UploadFile = File(...)):
    file_path = os.path.join(UPLOAD_DIR, file.filename)

    contents = await file.read()

    with open(file_path, "wb") as f:
        f.write(contents)

    return {"filename": file.filename, "message": "File uploaded and saved successfully"}